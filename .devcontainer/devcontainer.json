{
  "name": "owox-harness-dev",
  "dockerComposeFile": "compose.yml",
  "service": "dev",
  "runServices": [
    "dev"
  ],
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "updateRemoteUserUID": true,
  "postStartCommand": "([ -x /home/vscode/.local/bin/claude ] || curl -fsSL https://claude.ai/install.sh | bash)",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.npm-global/bin:/home/vscode/.local/bin:/home/vscode/.local/share/pnpm"
  },
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  }
}